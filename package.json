{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "github-navigator",
  "title": "GitHub Navigator",
  "description": "Navigate your GitHub projects",
  "icon": "extension-icon.svg",
  "author": "webpro",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "navigate-github",
      "title": "Navigate GitHub",
      "subtitle": "Navigate your GitHub projects",
      "description": "Navigate your GitHub projects",
      "mode": "view",
      "keywords": [
        "github"
      ],
      "preferences": [
        {
          "name": "personalAccessToken",
          "type": "password",
          "required": true,
          "title": "GitHub Token",
          "description": "Your GitHub's personal access token. Required scopes: notifications repo project read:org read:user.",
          "link": "https://github.com/settings/tokens",
          "placeholder": "Enter your personal access token"
        },
        {
          "name": "sortBy",
          "type": "dropdown",
          "required": true,
          "title": "Sort Repositories By",
          "description": "Choose the metric to sort repositories",
          "data": [
            {
              "title": "Stars",
              "value": "stargazers_count"
            },
            {
              "title": "Open Issues",
              "value": "open_issues_count"
            },
            {
              "title": "Pull Requests",
              "value": "open_prs_count"
            }
          ],
          "default": "stargazers_count"
        },
        {
          "name": "showStars",
          "type": "checkbox",
          "required": false,
          "title": "Labels",
          "label": "Stars",
          "description": "Show star count label",
          "default": true
        },
        {
          "name": "showIssuesPRs",
          "type": "checkbox",
          "required": false,
          "label": "Issues/PRs",
          "description": "Show open issues/PRs label",
          "default": true
        },
        {
          "name": "reuseTab",
          "type": "checkbox",
          "required": false,
          "title": "Browser",
          "label": "Reuse existing browser tab",
          "description": "Focus an existing tab if the URL is already open, instead of opening a new tab",
          "default": false
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.88.4",
    "@raycast/utils": "^1.17.0",
    "open-in-browser-tab": "^0.0.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "20.8.10",
    "@types/react": "18.3.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
